

(defun gen ()
       (yield xxx)
       (yield yyy)
       (yield zzz))



(defun gen ()
       (let state (gensym 'state)
            (begin (set state 0)
                   (lambda ()
                            (cond (value state)
                                  ((= state 0) xxx)
                                  ((= state 1) yyy)
                                  ((= state 2) zzz)
                                  (#t ...))))))